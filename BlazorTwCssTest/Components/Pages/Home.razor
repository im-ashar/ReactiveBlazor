@page "/"
@attribute [StreamRendering]

<PageTitle>Contact Us</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-base-200 p-4">
    <div class="card bg-base-100 shadow-xl w-full max-w-lg">
        <div class="card-body">
            <h1 class="card-title text-2xl font-bold justify-center mb-2">Contact Us</h1>
            <p class="text-center text-base-content/60 mb-6">We'd love to hear from you. Send us a message!</p>

            <EditForm method="post" Model="@_model" OnValidSubmit="HandleSubmit" FormName="ContactForm" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary class="text-error text-sm mb-4" />

                <fieldset class="fieldset gap-4">
                    @* Name *@
                    <div class="form-control w-full">
                        <label class="label" for="name">
                            <span class="label-text font-medium">Name</span>
                        </label>
                        <InputText id="name" @bind-Value="_model.Name"
                                   class="input input-bordered w-full"
                                   placeholder="John Doe" />
                        <ValidationMessage For="@(() => _model.Name)" class="text-error text-xs mt-1" />
                    </div>
                    @* Submit *@
                    <div class="form-control mt-4">
                        <button type="submit" class="btn btn-primary w-full">
                            Send Message
                        </button>
                    </div>
                </fieldset>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private ContactFormModel _model { get; set; } = default!;

    protected override void OnInitialized()
    {
        _model ??= new();
    }

    private async Task HandleSubmit()
    {
        // Simulate DB processing
        await Task.Delay(500);

        // Show success toast

        // Reset form
        _model = new();
    }

    private sealed class ContactFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(100)]
        public string Name { get; set; } = "";
    }
}
