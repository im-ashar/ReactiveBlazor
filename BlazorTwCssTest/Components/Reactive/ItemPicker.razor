@inherits ReactiveBlazor.ReactiveComponent
@* Your original motivating example: reflect the user's selection without a full page reload. *@
<ReactiveBlazor.ReactiveRoot Owner="this">
    <label>
        Pick a fruit:
        <select data-bind="Selected" data-on-change>
            <option value="">--</option>
            @foreach (var fruit in Fruits)
            {
                <option value="@fruit" selected="@(fruit == Selected)">@fruit</option>
            }
        </select>
    </label>

    @if (!string.IsNullOrEmpty(Selected))
    {
        <p>You selected: <strong>@Selected</strong></p>
    }
</ReactiveBlazor.ReactiveRoot>

@code {
    public string Selected { get; set; } = "";

    // NOTE: as written this list is part of the serialized state and round-trips on every change.
    // For static/large data prefer rebuilding it in OnInitialized instead of storing it as state.
    public string[] Fruits { get; set; } = { "Apple", "Banana", "Cherry" };
}
