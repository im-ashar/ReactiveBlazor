@using BlazorTwCssTest.Toast

@if (Toast is not null)
{
    <div id="toast-@_renderId"
         class="toast toast-top toast-end z-50"
         x-data="{ show: false }"
         x-init="$nextTick(() => { show = true; setTimeout(() => show = false, 4000) })"
         x-show="show"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-x-8"
         x-transition:enter-end="opacity-100 translate-x-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 translate-x-0"
         x-transition:leave-end="opacity-0 translate-x-8">
        <div class="alert @AlertClass shadow-lg">
            @* Icon *@
            @switch (Toast.Type)
            {
                case ToastType.Success:
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    break;
                case ToastType.Error:
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    break;
                case ToastType.Warning:
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                    break;
                case ToastType.Info:
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    break;
            }
            <span>@Toast.Message</span>
            <button class="btn btn-ghost btn-xs" @@click="show = false">✕</button>
        </div>
    </div>
}

@code {
    [Parameter]
    public ToastMessage? Toast { get; set; }

    /// Unique ID per render so Alpine.js re-initializes on each enhanced navigation patch.
    private string _renderId = Guid.NewGuid().ToString("N")[..8];

    private string AlertClass => Toast?.Type switch
    {
        ToastType.Success => "alert-success",
        ToastType.Error   => "alert-error",
        ToastType.Warning => "alert-warning",
        ToastType.Info    => "alert-info",
        _                 => "alert-info"
    };
}
