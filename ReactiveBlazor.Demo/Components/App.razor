<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ReactiveBlazor Demo</title>
    <meta name="description" content="Interactive demo of ReactiveBlazor � stateful SSR components without SignalR or WebAssembly." />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.output.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["ReactiveBlazor.Demo.styles.css"]" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
    <ReactiveBlazor.ReactiveScripts ScriptPath="@Assets["_content/ReactiveBlazor/reactive.js"]" />
    <script>
            window.scrollTo = undefined;
    </script>
</head>
<body class="font-sans">
    <Routes />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        // Surface ReactiveBlazor dispatch errors as a lightweight toast. A 403 (authenticated but
        // not allowed) lands here; a 401 (unauthenticated) is handled by the runtime itself, which
        // stops polling and reloads so the app's login redirect fires.
        document.addEventListener("reactive:error", function (e) {
            var status = e.detail && e.detail.status;
            var msg = status === 403
                ? "Not authorized to perform that action (403)."
                : "Request failed" + (status ? " (" + status + ")." : ".");
            var toast = document.createElement("div");
            toast.className = "toast toast-top toast-end";
            // Inline z-index (not a Tailwind class) so it reliably sits above the sticky navbar
            // without depending on the build-time CSS scanner picking up a class from this string.
            toast.style.zIndex = "9999";
            toast.innerHTML = '<div class="alert alert-error shadow-lg"><span>' + msg + '</span></div>';
            document.body.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 3500);
        });
    </script>
    <script src="@Assets["replay-lab.js"]"></script>
</body>
</html>
