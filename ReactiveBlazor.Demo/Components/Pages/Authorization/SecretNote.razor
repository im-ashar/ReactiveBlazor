@inherits ReactiveBlazor.ReactiveComponent

@*
    A reactive component holding a per-user "secret". Its value is serialized into the encrypted
    state token. The Replay Lab uses this to demonstrate ReactiveOptions.BindStateToUser: a token
    captured as one user, replayed by another, resets to default instead of revealing the secret.
*@

<ReactiveRoot Owner="this">
    <div class="card bg-base-100 border border-primary/40 shadow-sm" id="secret-note">
        <div class="card-body p-5 space-y-3">
            <div class="flex items-center justify-between">
                <h3 class="font-bold text-base">Your private note</h3>
                <span class="badge badge-sm badge-primary badge-outline font-mono">state token</span>
            </div>

            <input type="text"
                   class="input input-bordered input-sm w-full"
                   placeholder="Type a secret only you should see…"
                   data-bind="Secret"
                   value="@Secret"
                   data-on-input="Save"
                   data-debounce="200" />

            <div class="text-sm">
                Saved note:
                <span id="secret-value" class="font-mono font-semibold text-primary">@(string.IsNullOrEmpty(Secret) ? "(empty)" : Secret)</span>
            </div>
            <div class="text-[11px] text-base-content/50 font-mono border-t border-base-300 pt-2">
                Saves: @Saves · Rendered @RenderedAt
            </div>
        </div>
    </div>
</ReactiveRoot>

@code {
    public string Secret { get; set; } = "";
    public int Saves { get; set; }
    public string RenderedAt { get; set; } = "";

    protected override void OnInitialized() => RenderedAt = DateTime.Now.ToString("HH:mm:ss");

    // Bindings are applied before this runs, so Secret already holds the typed value.
    [ReactiveAction]
    public void Save() => Saves++;

    // Harmless action the Replay Lab invokes when replaying a token.
    [ReactiveAction]
    public void Touch() { }
}
