@page "/cart"

<PageTitle>Your Shopping Cart - ReactiveBlazor Store</PageTitle>

<div class="max-w-6xl mx-auto space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-base-content">Your Shopping Cart</h1>
            <p class="text-sm text-base-content/50 mt-1">Manage your items and proceed to checkout.</p>
        </div>
        <a href="/" class="btn btn-outline btn-sm gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Continue Shopping
        </a>
    </div>

    <!-- Render the reactive CartEditor component -->
    <CartEditor />
</div>
