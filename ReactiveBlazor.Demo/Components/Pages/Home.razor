@page "/"
@inherits Microsoft.AspNetCore.Components.ComponentBase

<PageTitle>Overview - ReactiveBlazor Dashboard</PageTitle>

<div class="space-y-8">
    <!-- Hero / Welcome Banner -->
    <div class="hero bg-gradient-to-br from-primary/10 via-base-100 to-secondary/10 rounded-2xl p-8 border border-base-300 shadow-sm">
        <div class="hero-content text-center max-w-3xl mx-auto">
            <div>
                <h1 class="text-4xl font-extrabold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent mb-4">
                    ReactiveBlazor
                </h1>
                <p class="text-base-content/75 text-lg leading-relaxed">
                    Stateful interactive components for Blazor Static SSR —
                    <span class="font-semibold text-base-content">no SignalR, no WebAssembly.</span>
                    Enjoy near-zero client JS, encrypted state, anti-replay tokens, and automatic multi-component out-of-band updates using Idiomorph morphing.
                </p>
                <div class="mt-6 flex justify-center gap-3">
                    <a href="/shop" class="btn btn-primary">Try Shop Demo</a>
                    <a href="https://github.com/im-ashar/ReactiveBlazor" target="_blank" class="btn btn-outline">GitHub Repository</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="stat bg-base-100 border border-base-300 rounded-xl shadow-sm">
            <div class="stat-title text-base-content/60">Client JS Size</div>
            <div class="stat-value text-primary text-2xl font-black">~7.4 KB</div>
            <div class="stat-desc text-base-content/40">Zero runtime dependencies</div>
        </div>
        <div class="stat bg-base-100 border border-base-300 rounded-xl shadow-sm">
            <div class="stat-title text-base-content/60">State Encryption</div>
            <div class="stat-value text-secondary text-2xl font-black">AES-256</div>
            <div class="stat-desc text-base-content/40">ASP.NET Data Protection</div>
        </div>
        <div class="stat bg-base-100 border border-base-300 rounded-xl shadow-sm">
            <div class="stat-title text-base-content/60">Interactivity</div>
            <div class="stat-value text-success text-2xl font-black">AJAX HTTP</div>
            <div class="stat-desc text-base-content/40">No WebSockets required</div>
        </div>
        <div class="stat bg-base-100 border border-base-300 rounded-xl shadow-sm">
            <div class="stat-title text-base-content/60">DOM Morphing</div>
            <div class="stat-value text-accent text-2xl font-black">Idiomorph</div>
            <div class="stat-desc text-base-content/40">Preserves scroll, focus, transitions</div>
        </div>
    </div>

    <!-- Architecture Breakdown -->
    <div class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body p-6">
            <h2 class="card-title text-xl font-bold mb-4 text-base-content">How It Works: The Lifecycle</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4 text-center text-xs mt-2">
                <div class="flex flex-col items-center bg-base-200/50 p-4 rounded-xl border border-base-300/30">
                    <span class="text-2xl mb-2">🖱️</span>
                    <span class="font-bold text-base-content">1. Event Trigger</span>
                    <span class="text-base-content/60 mt-1">User clicks elements with data-on-* attributes.</span>
                </div>
                
                <div class="flex flex-col items-center bg-base-200/50 p-4 rounded-xl border border-base-300/30">
                    <span class="text-2xl mb-2">📦</span>
                    <span class="font-bold text-base-content">2. State Bundle</span>
                    <span class="text-base-content/60 mt-1">Client JS scans active components and posts current state.</span>
                </div>
                
                <div class="flex flex-col items-center bg-base-200/50 p-4 rounded-xl border border-base-300/30">
                    <span class="text-2xl mb-2">🔑</span>
                    <span class="font-bold text-base-content">3. Unprotect</span>
                    <span class="text-base-content/60 mt-1">Server validates anti-forgery, decrypts, and verifies states.</span>
                </div>
                
                <div class="flex flex-col items-center bg-base-200/50 p-4 rounded-xl border border-base-300/30">
                    <span class="text-2xl mb-2">⚡</span>
                    <span class="font-bold text-base-content">4. Dispatch</span>
                    <span class="text-base-content/60 mt-1">Server executes target action method to mutate state.</span>
                </div>
                
                <div class="flex flex-col items-center bg-base-200/50 p-4 rounded-xl border border-base-300/30">
                    <span class="text-2xl mb-2">🖌️</span>
                    <span class="font-bold text-base-content">5. Batch Render</span>
                    <span class="text-base-content/60 mt-1">Server renders target and sibling components inside dispatcher.</span>
                </div>
                
                <div class="flex flex-col items-center bg-base-200/50 p-4 rounded-xl border border-base-300/30">
                    <span class="text-2xl mb-2">🔄</span>
                    <span class="font-bold text-base-content">6. OOB Morph</span>
                    <span class="text-base-content/60 mt-1">Client swaps and morphs DOM elements out-of-band.</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Feature Showcase Grid -->
    <div class="space-y-4">
        <h2 class="text-2xl font-bold text-base-content">Feature Catalog</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Counter Card -->
            <div class="card bg-base-100 border border-base-300 shadow-sm flex flex-col justify-between hover:shadow-md hover:border-primary/20 transition-all duration-300">
                <div class="card-body p-6">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="badge badge-sm badge-primary badge-outline">Actions</span>
                        <span class="text-[10px] text-base-content/40">data-args</span>
                    </div>
                    <h3 class="card-title text-base font-bold text-base-content">Stateful Actions</h3>
                    <p class="text-xs text-base-content/60 leading-relaxed mt-1">
                        Methods decorated with <code class="text-primary">[ReactiveAction]</code> are invoked directly from C# via data attributes, passing primitive arguments cleanly.
                    </p>
                </div>
                <div class="p-5 pt-0">
                    <NavLink href="/counter" class="btn btn-primary btn-sm btn-block">Explore Counter</NavLink>
                </div>
            </div>

            <!-- Bindings Card -->
            <div class="card bg-base-100 border border-base-300 shadow-sm flex flex-col justify-between hover:shadow-md hover:border-primary/20 transition-all duration-300">
                <div class="card-body p-6">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="badge badge-sm badge-secondary badge-outline">Two-way</span>
                        <span class="text-[10px] text-base-content/40">data-bind</span>
                    </div>
                    <h3 class="card-title text-base font-bold text-base-content">Two-Way Bindings</h3>
                    <p class="text-xs text-base-content/60 leading-relaxed mt-1">
                        Use <code class="text-secondary">data-bind</code> to sync dropdowns, inputs, checkboxes, and radios back to C# property states automatically.
                    </p>
                </div>
                <div class="p-5 pt-0">
                    <NavLink href="/picker" class="btn btn-secondary btn-sm btn-block">Explore Bindings</NavLink>
                </div>
            </div>

            <!-- Todo Card -->
            <div class="card bg-base-100 border border-base-300 shadow-sm flex flex-col justify-between hover:shadow-md hover:border-primary/20 transition-all duration-300">
                <div class="card-body p-6">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="badge badge-sm badge-warning badge-outline">Complex</span>
                        <span class="text-[10px] text-base-content/40">List&lt;T&gt; state</span>
                    </div>
                    <h3 class="card-title text-base font-bold text-base-content">Complex Collections</h3>
                    <p class="text-xs text-base-content/60 leading-relaxed mt-1">
                        Supports serialization of complex data lists and generic sub-entities. The compiler signs and secures the nested object graph on every request.
                    </p>
                </div>
                <div class="p-5 pt-0">
                    <NavLink href="/todo" class="btn btn-warning btn-sm btn-block">Explore Task Manager</NavLink>
                </div>
            </div>

            <!-- Debounce Card -->
            <div class="card bg-base-100 border border-base-300 shadow-sm flex flex-col justify-between hover:shadow-md hover:border-primary/20 transition-all duration-300">
                <div class="card-body p-6">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="badge badge-sm badge-accent badge-outline">Optimization</span>
                        <span class="text-[10px] text-base-content/40">data-debounce</span>
                    </div>
                    <h3 class="card-title text-base font-bold text-base-content">Input Debouncing</h3>
                    <p class="text-xs text-base-content/60 leading-relaxed mt-1">
                        Add <code class="text-accent">data-debounce="N"</code> on input fields to delay dispatches, avoiding overloading server resources when users type rapidly.
                    </p>
                </div>
                <div class="p-5 pt-0">
                    <NavLink href="/search" class="btn btn-accent btn-sm btn-block">Explore Live Search</NavLink>
                </div>
            </div>

            <!-- OOB Card -->
            <div class="card bg-base-100 border border-base-300 shadow-sm flex flex-col justify-between hover:shadow-md hover:border-primary/20 transition-all duration-300">
                <div class="card-body p-6">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="badge badge-sm badge-info badge-outline">OOB Swap</span>
                        <span class="text-[10px] text-base-content/40">No-JS Glue</span>
                    </div>
                    <h3 class="card-title text-base font-bold text-base-content">Out-of-Band (OOB) Updates</h3>
                    <p class="text-xs text-base-content/60 leading-relaxed mt-1">
                        Updates to global state from an action automatically re-render and morph all other sibling components on the page in a single request.
                    </p>
                </div>
                <div class="p-5 pt-0">
                    <NavLink href="/shop" class="btn btn-info btn-sm btn-block">Explore OOB E-Commerce</NavLink>
                </div>
            </div>

            <!-- Reactive Signals Card -->
            <div class="card bg-base-100 border border-base-300 shadow-sm flex flex-col justify-between hover:shadow-md hover:border-primary/20 transition-all duration-300">
                <div class="card-body p-6">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="badge badge-sm badge-secondary badge-outline">Signals</span>
                        <span class="text-[10px] text-base-content/40">[OnReactiveSignal&lt;T&gt;]</span>
                    </div>
                    <h3 class="card-title text-base font-bold text-base-content">Reactive Signals (Typed OOB)</h3>
                    <p class="text-xs text-base-content/60 leading-relaxed mt-1">
                        Publish strongly-typed <code class="text-secondary">IReactiveSignal</code> records from actions. Subscribed components re-render and can read the payload via <code class="text-secondary">GetPublished&lt;T&gt;()</code> in <code class="text-secondary">OnInitialized</code>.
                    </p>
                </div>
                <div class="p-5 pt-0">
                    <NavLink href="/notifications" class="btn btn-secondary btn-sm btn-block">Explore Multi-Signal Demo</NavLink>
                </div>
            </div>

            <!-- Authorization Card -->
            <div class="card bg-base-100 border border-base-300 shadow-sm flex flex-col justify-between hover:shadow-md hover:border-primary/20 transition-all duration-300">
                <div class="card-body p-6">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="badge badge-sm badge-error badge-outline">Security</span>
                        <span class="text-[10px] text-base-content/40">[Authorize]</span>
                    </div>
                    <h3 class="card-title text-base font-bold text-base-content">Declarative Authorization</h3>
                    <p class="text-xs text-base-content/60 leading-relaxed mt-1">
                        Use the framework's own <code class="text-error">[Authorize]</code> / <code class="text-error">[AllowAnonymous]</code> on actions and components. Roles, policies, and <code class="text-error">&lt;AuthorizeView&gt;</code> all work — denied components emit no state token, and unauthorized signal siblings are never returned.
                    </p>
                </div>
                <div class="p-5 pt-0">
                    <NavLink href="/authorization" class="btn btn-error btn-sm btn-block">Explore Authorization</NavLink>
                </div>
            </div>

            <!-- Token Replay Lab Card -->
            <div class="card bg-base-100 border border-base-300 shadow-sm flex flex-col justify-between hover:shadow-md hover:border-primary/20 transition-all duration-300">
                <div class="card-body p-6">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="badge badge-sm badge-error badge-outline">Security</span>
                        <span class="text-[10px] text-base-content/40">BindStateToUser</span>
                    </div>
                    <h3 class="card-title text-base font-bold text-base-content">Token Replay Lab</h3>
                    <p class="text-xs text-base-content/60 leading-relaxed mt-1">
                        Capture an encrypted state token as one user, switch users, and replay it. With <code class="text-error">BindStateToUser</code> on, the component resets instead of leaking the first user's data — see the cross-user replay defense live.
                    </p>
                </div>
                <div class="p-5 pt-0">
                    <NavLink href="/replay-lab" class="btn btn-error btn-sm btn-block">Open Replay Lab</NavLink>
                </div>
            </div>
        </div>
    </div>
</div>
