@page "/notifications"

<PageTitle>Multi-Signal Demo - ReactiveBlazor</PageTitle>

<div class="space-y-6">
    <!-- Page header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between border-b border-base-300 pb-4 gap-4">
        <div>
            <h1 class="text-3xl font-bold text-base-content">Multi-Signal OOB Updates</h1>
            <p class="text-sm text-base-content/60 mt-1">
                Three signal types, three subscribers, one isolated component.
                Use the composer and watch the <em>"Rendered at"</em> timestamps to see which
                components were re-rendered.
            </p>
        </div>
        <div class="badge badge-secondary badge-outline font-semibold gap-2 py-3 px-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            IReactiveSignal Demo
        </div>
    </div>

    <!-- Signals legend -->
    <div class="card bg-base-200/40 border border-base-300">
        <div class="card-body p-4">
            <h3 class="font-bold text-sm mb-2">Signals in this demo</h3>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 text-xs font-mono">
                <code class="bg-base-100 p-2 rounded border border-base-300">NotificationAdded(int Id, string Level)</code>
                <code class="bg-base-100 p-2 rounded border border-base-300">NotificationRead(int Id)</code>
                <code class="bg-base-100 p-2 rounded border border-base-300">NotificationsCleared</code>
            </div>
        </div>
    </div>

    <!-- Layout: composer on left, three reactive widgets on right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <NotificationComposer />
        <div class="space-y-4">
            <NotificationBell />
            <NotificationList />
            <IsolatedClock />
        </div>
    </div>

    <!-- Expectation table -->
    <div class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body p-5">
            <h3 class="font-bold text-base mb-3">Expected behavior</h3>
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Composer action</th>
                            <th>Bell</th>
                            <th>Feed</th>
                            <th>Isolated Clock</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>+ Info / + Success / + Warning</code></td>
                            <td class="text-success">re-renders</td>
                            <td class="text-success">re-renders</td>
                            <td class="text-warning">unchanged</td>
                        </tr>
                        <tr>
                            <td><code>Mark 1 read</code></td>
                            <td class="text-success">re-renders</td>
                            <td class="text-base-content/50">unchanged <em>(not subscribed)</em></td>
                            <td class="text-warning">unchanged</td>
                        </tr>
                        <tr>
                            <td><code>Clear all</code></td>
                            <td class="text-success">re-renders</td>
                            <td class="text-success">re-renders</td>
                            <td class="text-warning">unchanged</td>
                        </tr>
                        <tr>
                            <td><code>Refresh clock</code> (on Isolated Clock)</td>
                            <td class="text-base-content/50">unchanged <em>(no signal)</em></td>
                            <td class="text-base-content/50">unchanged <em>(no signal)</em></td>
                            <td class="text-success">re-renders <em>(target)</em></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <p class="text-xs text-base-content/60 mt-3">
                Tip: open DevTools → Network and inspect each dispatch response. The JSON
                payload only contains entries for the target component plus any components
                whose <code>[OnReactiveSignal&lt;T&gt;]</code> matches a published signal.
            </p>
        </div>
    </div>
</div>
