@inherits ReactiveBlazor.ReactiveComponent
@attribute [OnReactiveSignal<MetricsSampled>]

@* This component never polls and is never the dispatch target. It re-renders purely
   out-of-band: every poll tick on the dashboard publishes MetricsSampled, and this
   subscriber consumes the payload to append a log entry. *@
<ReactiveRoot Owner="this">
    <div class="card bg-base-100 border border-secondary/40 shadow-sm">
        <div class="card-body p-5">
            <div class="flex items-center justify-between mb-2">
                <div>
                    <h3 class="font-bold text-base">OOB Activity Log</h3>
                    <p class="text-[11px] text-base-content/50 font-mono mt-0.5">
                        subscribes: MetricsSampled
                    </p>
                </div>
                <span class="badge badge-secondary badge-outline">@Entries.Count samples</span>
            </div>

            @if (Entries.Count == 0)
            {
                <p class="text-sm text-base-content/50 italic">
                    Waiting for the first poll tick…
                </p>
            }
            else
            {
                <ul class="text-xs font-mono space-y-1 max-h-48 overflow-y-auto">
                    @foreach (var entry in Entries)
                    {
                        <li class="border-b border-base-200 pb-1">@entry</li>
                    }
                </ul>
            }

            <div class="mt-3 text-[11px] text-base-content/50 font-mono border-t border-base-300 pt-2">
                Rendered: <span class="text-secondary">@RenderedAt</span>
            </div>
        </div>
    </div>
</ReactiveRoot>

@code {
    // Most-recent-first, capped to keep the serialized state small.
    public List<string> Entries { get; set; } = [];
    public string RenderedAt { get; set; } = "";

    protected override void OnInitialized()
    {
        RenderedAt = DateTime.Now.ToString("HH:mm:ss.fff");

        // Append a log line for each MetricsSampled signal published this dispatch (if any).
        foreach (var sample in ReactiveSignals.GetPublished<MetricsSampled>())
            Entries.Insert(0, $"{sample.At:HH:mm:ss} — CPU {sample.Cpu:0.0}%");

        if (Entries.Count > 8)
            Entries = Entries.Take(8).ToList();
    }
}
