@page "/search"
@inherits ReactiveBlazor.ReactiveComponent
@inject ReactiveBlazor.Demo.Services.ProductService ProductService

<PageTitle>Debounced Search - ReactiveBlazor Demo</PageTitle>

<ReactiveRoot Owner="this">
    <div class="space-y-6">
        <!-- Page Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between border-b border-base-300 pb-4 gap-4">
            <div>
                <h1 class="text-3xl font-bold text-base-content">Debounced Live Search</h1>
                <p class="text-sm text-base-content/60 mt-1">Typing automatically queries the server in real-time, debounced to avoid overloading the network.</p>
            </div>
            <div class="badge badge-secondary badge-outline font-semibold gap-2 py-3 px-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Debounce Demo
            </div>
        </div>

        <!-- Search Controls Card -->
        <div class="card bg-base-100 border border-base-300 shadow-sm">
            <div class="card-body p-6 space-y-4">
                <div class="flex flex-col md:flex-row gap-4 items-end">
                    <div class="form-control w-full max-w-md">
                        <label class="label">
                            <span class="label-text font-semibold">Search Catalog</span>
                        </label>
                        <div class="relative">
                            <input type="text"
                                   class="input input-bordered w-full pl-10"
                                   placeholder="Type to search (e.g. keyboard, monitor)..."
                                   data-bind="Query"
                                   value="@Query"
                                   data-on-input="DoSearch"
                                   data-debounce="250" />
                            <span class="absolute inset-y-0 left-3 flex items-center text-base-content/40">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </span>
                        </div>
                    </div>
                    
                    <div class="text-xs text-base-content/50 md:pb-3 tabular-nums">
                        @if (!string.IsNullOrEmpty(LastSearchTime))
                        {
                            <span>Last server round-trip: <strong>@LastSearchTime</strong></span>
                        }
                    </div>
                </div>
                
                <div class="text-xs text-base-content/60 bg-base-200/50 p-3 rounded-lg border border-base-300">
                    <strong>How it works:</strong> The input field is decorated with <code class="text-secondary">data-on-input="DoSearch"</code> and <code class="text-secondary">data-debounce="250"</code>. The client runtime waits for a 250ms pause in typing before dispatching the state and query to the server via standard POST fetch.
                </div>
            </div>
        </div>

        <!-- Search Results -->
        <div class="space-y-4">
            <h2 class="font-bold text-lg text-base-content">Results (@FilteredProducts.Count)</h2>

            @if (FilteredProducts.Count == 0)
            {
                <div class="card bg-base-100 border border-base-300 shadow-sm p-12 text-center">
                    <div class="flex flex-col items-center max-w-md mx-auto">
                        <div class="w-16 h-16 rounded-full bg-base-200 flex items-center justify-center text-base-content/30 mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-lg mb-1">No Products Found</h3>
                        <p class="text-sm text-base-content/50">We couldn't find any products matching "@Query". Try typing "keyboard", "mouse", or "headphones".</p>
                    </div>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (var product in FilteredProducts)
                    {
                        <div class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md transition-all duration-300 flex flex-col justify-between overflow-hidden">
                            <div class="flex items-center gap-4 p-4 border-b border-base-200 bg-base-200/20">
                                <div class="w-14 h-14 rounded-lg overflow-hidden bg-base-200 border border-base-300 shrink-0">
                                    <img src="@product.ImageUrl" alt="@product.Name" class="w-full h-full object-cover" />
                                </div>
                                <div class="min-w-0 flex-1">
                                    <h3 class="font-bold text-sm text-base-content truncate">@product.Name</h3>
                                    <span class="text-xs font-semibold text-primary">@product.Price.ToString("C")</span>
                                </div>
                            </div>
                            <div class="p-4 flex-1">
                                <p class="text-xs text-base-content/60 leading-relaxed">@product.Description</p>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</ReactiveRoot>

@code {
    public string Query { get; set; } = "";
    public List<ReactiveBlazor.Demo.Models.Product> FilteredProducts { get; set; } = [];
    public string LastSearchTime { get; set; } = "";

    protected override void OnInitialized()
    {
        DoSearch();
    }

    [ReactiveAction]
    public void DoSearch()
    {
        var all = ProductService.GetProducts();
        if (string.IsNullOrWhiteSpace(Query))
        {
            FilteredProducts = all;
        }
        else
        {
            var q = Query.Trim().ToLowerInvariant();
            FilteredProducts = all.Where(p => 
                p.Name.ToLowerInvariant().Contains(q) || 
                p.Description.ToLowerInvariant().Contains(q)
            ).ToList();
        }
        LastSearchTime = DateTime.Now.ToString("HH:mm:ss.fff");
    }
}
