@page "/shop"
@inherits ReactiveBlazor.ReactiveComponent
@inject ReactiveBlazor.Demo.Services.ProductService ProductService
@inject ReactiveBlazor.Demo.Services.CartService CartService

<PageTitle>Developer Gear Shop - ReactiveBlazor Demo</PageTitle>

<ReactiveRoot Owner="this">
    <div class="space-y-6">
        <!-- Page Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between border-b border-base-300 pb-4 gap-4">
            <div>
                <h1 class="text-3xl font-bold text-base-content">Developer Gear Catalog</h1>
                <p class="text-sm text-base-content/60 mt-1">Select premium gear for your setup. All updates are reactive and stay in sync globally.</p>
            </div>
            <div class="badge badge-primary badge-outline font-semibold gap-2 py-3 px-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                OOB Updates Demo
            </div>
        </div>

        <!-- Product Catalog Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var product in Products)
            {
                var qtyInCart = GetQuantityInCart(product.Id);
                <div class="card bg-base-100 border border-base-300 shadow-md hover:shadow-lg hover:border-primary/30 transition-all duration-300 flex flex-col justify-between overflow-hidden">
                    <figure class="h-48 bg-base-200 overflow-hidden relative">
                        <img src="@product.ImageUrl" alt="@product.Name" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
                        @if (qtyInCart > 0)
                        {
                            <span class="absolute top-3 right-3 badge badge-primary font-bold shadow-sm p-3">
                                @qtyInCart in Cart
                            </span>
                        }
                    </figure>
                    <div class="card-body p-5 flex-1 flex flex-col justify-between">
                        <div>
                            <div class="flex justify-between items-start mb-2">
                                <h3 class="card-title text-base font-bold text-base-content leading-tight">@product.Name</h3>
                                <span class="font-extrabold text-primary tabular-nums">@product.Price.ToString("C")</span>
                            </div>
                            <p class="text-xs text-base-content/60 leading-relaxed mb-4">@product.Description</p>
                        </div>
                        <div class="card-actions mt-2">
                            <button type="button"
                                    class="btn btn-primary btn-sm btn-block gap-2"
                                    data-on-click="AddProductToCart"
                                    data-args="@($"[{product.Id}]")">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                                @(qtyInCart > 0 ? "Add More" : "Add to Cart")
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</ReactiveRoot>

@code {
    public List<ReactiveBlazor.Demo.Models.Product> Products { get; set; } = [];
    public Dictionary<int, int> CartQuantities { get; set; } = [];

    protected override void OnInitialized()
    {
        Products = ProductService.GetProducts();
        RefreshCartQuantities();
    }

    private void RefreshCartQuantities()
    {
        var items = CartService.GetCartItems();
        CartQuantities = items.ToDictionary(i => i.ProductId, i => i.Quantity);
    }

    private int GetQuantityInCart(int productId)
    {
        return CartQuantities.TryGetValue(productId, out var qty) ? qty : 0;
    }

    [ReactiveAction]
    public void AddProductToCart(int productId)
    {
        CartService.AddToCart(productId);
        RefreshCartQuantities();
    }
}
